package main

//Constants in Golang support character values, strings, boolean, and numbers.

import (
	"fmt"
	"math"
)

// const declares a constant value.

const s string = "constant"

func main() {

	fmt.Println(s)

	// A const statement can appear anywhere a var

	const n = 500000000

	// Constant expressions perform arithmetic with
	// arbitrary precision.

	const f = 3e20 / n

	fmt.Println(f)

	// A numeric constant has no type until it's given

	// one, such as by an explicit cast.

	fmt.Println(int64(f))

	//A number can be given a type by using it in a context that requires one
	//such as a variable assignment or function call. For example,
	// here math.Sin expects a float64.

	fmt.Println(math.Sin(n))

}

// output :
// constant
//6e+11
//600000000000
//-0.28470407323754404

//more details :
//Constants can be constructed wherever a variable can be constructed.
//The general difference between constants and variables is that the value of constants cannot be changed.
//In Golang, it can not be placed inside a functional constant, and only certain data types that we mentioned earlier can be used.

